# Game Mode Configuration
# Set to "true" to enable Tivoli mode (connected to main tivoli site)
# Set to "false" for standalone mode
NEXT_PUBLIC_TIVOLI_MODE=false

NEXT_PUBLIC_ENTRY_PRICE=4
NEXT_PUBLIC_SELLER="example-seller"
NEXT_PUBLIC_ACCESS_KEY="your-api-key-here"

# Set the environment (production or development)
NODE_ENV="development"
